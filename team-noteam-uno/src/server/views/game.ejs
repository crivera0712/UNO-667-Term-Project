<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UNO - Game</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&family=Righteous&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Styles -->
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/utils.css">
    <link rel="stylesheet" href="/css/components/menu.css">
    <link rel="stylesheet" href="/css/components/modal.css">
    <style>
        .game-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
            background: rgba(15, 15, 25, 0.95);
            border-radius: 24px;
            box-shadow: 0 0 40px rgba(255, 0, 0, 0.2);
        }

        .game-board {
            display: grid;
            grid-template-rows: auto 1fr auto;
            gap: 2rem;
            min-height: 70vh;
        }

        .opponents-area {
            display: flex;
            justify-content: space-around;
            padding: 1rem;
        }

        .player-area {
            display: flex;
            justify-content: center;
            padding: 1rem;
        }

        .play-area {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 2rem;
            padding: 2rem;
        }

        .deck, .discard-pile {
            width: 120px;
            height: 180px;
            border-radius: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            transition: transform 0.3s ease;
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2);
        }

        .card {
            width: 100px;
            height: 150px;
            border-radius: 10px;
            margin: 0 5px;
            cursor: pointer;
            transition: transform 0.3s ease;
            position: relative;
            background: white;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 2rem;
            color: white;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
        }

        .card:hover {
            transform: translateY(-10px);
        }

        .card.red { background: linear-gradient(135deg, #ff6b6b, #ff5252); }
        .card.blue { background: linear-gradient(135deg, #4facfe, #00f2fe); }
        .card.green { background: linear-gradient(135deg, #00b09b, #96c93d); }
        .card.yellow { background: linear-gradient(135deg, #ffd86f, #fc6262); }
        .card.wild { background: linear-gradient(45deg, #ff6b6b, #4facfe, #00b09b, #ffd86f); }

        .player-info {
            background: rgba(255, 255, 255, 0.1);
            padding: 1rem;
            border-radius: 10px;
            margin-bottom: 1rem;
            text-align: center;
        }

        .current-player {
            border: 2px solid #ff6b6b;
            box-shadow: 0 0 20px rgba(255, 107, 107, 0.3);
        }

        .hand {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 1rem;
            padding: 1rem;
        }

        .game-controls {
            display: flex;
            justify-content: center;
            gap: 1rem;
            padding: 1rem;
        }

        .btn {
            padding: 0.8rem 1.5rem;
            border-radius: 8px;
            border: none;
            background: linear-gradient(45deg, #ff6b6b, #ff5252);
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.3);
        }

        /* Color Picker Modal Styles */
        .color-options {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin: 2rem 0;
        }

        .color-button {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: 2px solid rgba(255, 255, 255, 0.2);
            cursor: pointer;
            transition: transform 0.3s ease;
        }

        .color-button:hover {
            transform: scale(1.1);
            border-color: rgba(255, 255, 255, 0.5);
        }

        .color-button.red { background: linear-gradient(135deg, #ff6b6b, #ff5252); }
        .color-button.blue { background: linear-gradient(135deg, #4facfe, #00f2fe); }
        .color-button.green { background: linear-gradient(135deg, #00b09b, #96c93d); }
        .color-button.yellow { background: linear-gradient(135deg, #ffd86f, #fc6262); }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: rgba(30, 30, 46, 0.95);
            padding: 2rem;
            border-radius: 16px;
            text-align: center;
            box-shadow: 0 0 30px rgba(255, 107, 107, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            max-width: 400px;
            width: 90%;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="title-container">
            <h1 class="title">UNO Game</h1>
        </div>

        <div class="game-container">
            <div class="player-info">
                <h2>Game ID: <%= gameId %></h2>
                <p>Player: <%= playerName %></p>
            </div>

            <div class="game-board">
                <div class="opponents-area" id="opponents">
                    <!-- Opponents will be rendered here -->
                </div>

                <div class="play-area">
                    <div class="deck" id="deck">
                        <i class="fas fa-layer-group"></i>
                    </div>
                    <div class="discard-pile" id="discardPile">
                        <!-- Top card will be rendered here -->
                    </div>
                </div>

                <div class="player-area">
                    <div class="hand" id="playerHand">
                        <!-- Player's cards will be rendered here -->
                    </div>
                </div>
            </div>

            <div class="game-controls">
                <button class="btn" id="drawCardBtn">Draw Card</button>
                <button class="btn" id="sayUnoBtn">Say UNO!</button>
            </div>
        </div>

        <!-- Color picker modal -->
        <div id="colorPickerModal" class="modal">
            <div class="modal-content">
                <h2>Choose a Color</h2>
                <div class="color-options">
                    <button class="color-button red" data-color="red"></button>
                    <button class="color-button blue" data-color="blue"></button>
                    <button class="color-button green" data-color="green"></button>
                    <button class="color-button yellow" data-color="yellow"></button>
                </div>
            </div>
        </div>
    </div>

    <script>
        const gameConfig = {
            gameId: '<%= gameId %>',
            playerId: '<%= playerId %>',
            playerName: '<%= playerName %>',
            isHost: '<%= isHost %>' === 'true'
        };
    </script>
    <script src="/js/game.js"></script>
</body>
</html>